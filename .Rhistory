get.ACF <- function(x) {
acf_result <- acf(na.omit(x$granularity), pl = FALSE)
data.frame(
lag = as.numeric(acf_result$lag),
acf = as.numeric(acf_result$acf)
)
}
ACFdata <- ICCdata %>%
group_by(mplusID) %>%
group_modify(~ get.ACF(.x) %>% as.data.frame()) %>%
ungroup()
get.ACF <- function(x) {
clean <- na.omit(x$granularity)
if (length(clean) < 2) return(data.frame(lag = NA, acf = NA))
acf_result <- acf(clean, pl = FALSE)
data.frame(
lag = as.numeric(acf_result$lag),
acf = as.numeric(acf_result$acf)
)
}
View(get.ACF)
ACFdata <- ICCdata %>%
group_by(mplusID) %>%
group_modify(~ get.ACF(.x) %>% as.data.frame()) %>%
ungroup()
View(ACFdata)
View(ACFdata)
ACFdata <- ACFdata %>%
group_by(mplusID) %>%
mutate(ACF_mean = mean(acf, na.rm = TRUE)) %>%
ungroup()
ACFsummary <- ACFdata %>%
group_by(mplusID) %>%
summarise(ACF_mean = mean(acf, na.rm = TRUE))
View(ACFsummary)
View(ACFsummary)
get.ACF1 <- function(x) {
clean <- na.omit(x[[var]])
if (length(clean) < 2) return(data.frame(lag = NA, acf = NA))
acf_result <- acf(clean, pl = FALSE)
data.frame(
lag = as.numeric(acf1_result$lag),
acf = as.numeric(acf1_result$acf)
)
}
